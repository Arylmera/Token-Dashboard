{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://token-dashboard.local/schemas/api-contract.json",
  "title": "Token Dashboard backend API contract",
  "description": "Schemas the Electron host + frontend depend on. See docs/API_CONTRACT.md for the prose version.",
  "$defs": {
    "ReadyLine": {
      "type": "object",
      "description": "JSON portion after the literal token TOKEN_DASHBOARD_READY on the ready stdout line.",
      "required": ["url", "host", "port", "pid", "ts"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "pid": { "type": "integer", "minimum": 1 },
        "db": { "type": "string" },
        "projects_dir": { "type": "string" },
        "ts": { "type": "number" }
      }
    },
    "Health": {
      "type": "object",
      "required": ["ok", "version", "now"],
      "properties": {
        "ok": { "const": true },
        "version": { "type": "string" },
        "started_at": { "type": ["number", "null"] },
        "uptime_s": { "type": ["number", "null"] },
        "now": { "type": "number" },
        "scan_interval_s": { "type": "number" },
        "projects_dir": { "type": ["string", "null"] },
        "db": { "type": ["string", "null"] },
        "sse_clients": { "type": "integer", "minimum": 0 }
      }
    },
    "Overview": {
      "type": "object",
      "required": ["sessions", "turns", "input_tokens", "output_tokens", "cost_usd"],
      "properties": {
        "sessions": { "type": "integer" },
        "turns": { "type": "integer" },
        "input_tokens": { "type": "integer" },
        "output_tokens": { "type": "integer" },
        "cache_read_tokens": { "type": "integer" },
        "cache_create_5m_tokens": { "type": "integer" },
        "cache_create_1h_tokens": { "type": "integer" },
        "cost_usd": { "type": "number" }
      }
    },
    "HourlyBucket": {
      "type": "object",
      "required": ["cost_usd", "billable_tokens"],
      "properties": {
        "cost_usd": { "type": "number" },
        "billable_tokens": { "type": "integer" }
      }
    },
    "Hourly": {
      "type": "array",
      "description": "Length equals ?hours= query param. Index 0 is oldest, last is most recent.",
      "items": { "$ref": "#/$defs/HourlyBucket" }
    },
    "SSEEvent": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "n", "ts"],
          "properties": {
            "type": { "const": "scan" },
            "n": {
              "type": "object",
              "required": ["files", "messages", "tools"],
              "properties": {
                "files": { "type": "integer" },
                "messages": { "type": "integer" },
                "tools": { "type": "integer" }
              }
            },
            "ts": { "type": "number" }
          }
        },
        {
          "type": "object",
          "required": ["type", "message"],
          "properties": {
            "type": { "const": "error" },
            "message": { "type": "string" }
          }
        }
      ]
    },
    "TrayDisplay": {
      "type": "object",
      "description": "Compact shape the Electron main process pushes to the OS shell (Win taskbar overlay, macOS tray title).",
      "required": ["billable_tokens", "cost_usd_today"],
      "properties": {
        "billable_tokens": { "type": "integer" },
        "cost_usd_today": { "type": "number" },
        "formatted": { "type": "string", "description": "Pre-formatted display string, e.g. '1.2k' or '$3.45'." },
        "ts": { "type": "number" }
      }
    }
  }
}
