{
  "name": "token-dashboard-electron",
  "version": "1.0.0",
  "description": "Electron desktop shell for Token Dashboard.",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dev:devtools": "electron . --dev",
    "frontend:build": "npm --prefix ../frontend run build",
    "py:prepare": "python3 scripts/prepare-py.py",
    "prebuild": "npm run frontend:build && npm run py:prepare",
    "prebuild:win": "npm run prebuild",
    "prebuild:mac": "npm run prebuild",
    "prebuild:linux": "npm run prebuild",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.arylmera.token-dashboard",
    "productName": "Token Dashboard",
    "publish": null,
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "afterPack": "scripts/ad-hoc-sign.js",
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "src/**/*",
      "build-resources/icon.png"
    ],
    "extraResources": [
      {
        "from": "../dist-py",
        "to": "py",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build-resources/icon.ico",
      "artifactName": "token-dashboard-${version}-windows-x64-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "guid": "b8a9c3d2-1e7f-4d5b-9c6a-3f8e2d1b7c4a"
    },
    "mac": {
      "target": "dmg",
      "icon": "build-resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "token-dashboard-${version}-macos-arm64.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build-resources/icon.png",
      "category": "Development",
      "artifactName": "token-dashboard-${version}-linux-x64.${ext}"
    }
  }
}
